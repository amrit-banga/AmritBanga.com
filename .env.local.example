# ──────────────────────────────────────────────────────────────────────────────
# Environment Variables — copy this file to .env.local and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# Contact form email (optional — swap for Resend, Formspree, etc.)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CONTACT_EMAIL=your@email.com

# Formspree endpoint (alternative to server action)
# NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxx

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=

# ── Dashboard (required to use /dashboard) ────────────────────────────────────
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here
DASHBOARD_PASSWORD=your-dashboard-password

# Anthropic Claude API (required for AI summaries/scores)
ANTHROPIC_API_KEY=sk-ant-...
